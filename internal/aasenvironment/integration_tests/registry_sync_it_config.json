    "endpoint": "http://127.0.0.1:6004/lookup/shells/dXJuOmV4YW1wbGU6YWFzOnJlZ2lzdHJ5LXN5bmMtcG9zdA",
    "shouldMatch": "expected/registry_sync_post_lookup_links.json",
    "expectedStatus": 200
  },
  {
