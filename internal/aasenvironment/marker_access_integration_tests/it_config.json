    "expectedStatus": 200,
    "headers": { "Edc-Bpn": "BPN_COMPANY_001" }
  },
  {
    "context": "DTR regular token with BPN company 1 sees own markers",
    "method": "GET",
    "endpoint": "http://127.0.0.1:5004/api/v3/shell-descriptors",
