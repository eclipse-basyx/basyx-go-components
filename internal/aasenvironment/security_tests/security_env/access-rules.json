{
  "AllAccessPermissionRules": {
    "DEFATTRIBUTES": [
      {
        "name": "role_attr",
        "attributes": [
          { "CLAIM": "role" }
        ]
      }
    ],
    "DEFOBJECTS": [
      {
        "name": "upload_route",
        "objects": [
          { "ROUTE": "/upload" }
        ]
      },
      {
        "name": "serialization_route",
        "objects": [
          { "ROUTE": "/serialization" }
        ]
      },
      {
        "name": "superpath_routes",
        "objects": [
          { "ROUTE": "/shells/*/submodels/*" }
        ]
      },
      {
        "name": "aas_environment_admin_routes",
        "objects": [
          { "ROUTE": "/shells" },
          { "ROUTE": "/shells/*" },
          { "ROUTE": "/submodels" },
          { "ROUTE": "/submodels/*" }
        ]
      },
      {
        "name": "abac_policy_management",
        "objects": [
          { "ROUTE": "/security/abac" },
          { "ROUTE": "/security/abac/*" }
        ]
      }
    ],
    "DEFACLS": [
      {
        "name": "create_role",
        "acl": {
          "USEATTRIBUTES": "role_attr",
          "RIGHTS": ["CREATE"],
          "ACCESS": "ALLOW"
        }
      },
      {
        "name": "update_role",
        "acl": {
          "USEATTRIBUTES": "role_attr",
          "RIGHTS": ["UPDATE"],
          "ACCESS": "ALLOW"
        }
      },
      {
        "name": "read_role",
        "acl": {
          "USEATTRIBUTES": "role_attr",
          "RIGHTS": ["READ"],
          "ACCESS": "ALLOW"
        }
      },
      {
        "name": "admin_all",
        "acl": {
          "USEATTRIBUTES": "role_attr",
          "RIGHTS": ["ALL"],
          "ACCESS": "ALLOW"
        }
      }
    ],
    "DEFFORMULAS": [
      {
        "name": "role_is_viewer",
        "formula": {
          "$eq": [
            { "$attribute": { "CLAIM": "role" } },
            { "$strVal": "viewer" }
          ]
        }
      },
      {
        "name": "role_is_editor",
        "formula": {
          "$eq": [
            { "$attribute": { "CLAIM": "role" } },
            { "$strVal": "editor" }
          ]
        }
      },
      {
        "name": "role_is_admin",
        "formula": {
          "$eq": [
            { "$attribute": { "CLAIM": "role" } },
            { "$strVal": "admin" }
          ]
        }
      }
    ],
    "rules": [
      {
        "USEACL": "create_role",
        "USEOBJECTS": ["upload_route"],
        "USEFORMULA": "role_is_viewer"
      },
      {
        "USEACL": "update_role",
        "USEOBJECTS": ["upload_route"],
        "USEFORMULA": "role_is_editor"
      },
      {
        "USEACL": "read_role",
        "USEOBJECTS": ["serialization_route"],
        "USEFORMULA": "role_is_viewer"
      },
      {
        "USEACL": "admin_all",
        "USEOBJECTS": ["superpath_routes"],
        "USEFORMULA": "role_is_admin"
      },
      {
        "USEACL": "admin_all",
        "USEOBJECTS": ["aas_environment_admin_routes", "abac_policy_management"],
        "USEFORMULA": "role_is_admin"
      }
    ]
  }
}
