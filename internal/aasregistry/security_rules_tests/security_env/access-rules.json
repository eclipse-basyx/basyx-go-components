{
  "AllAccessPermissionRules": {
    "DEFATTRIBUTES": [
      { "name": "anonym_attr", "attributes": [ { "GLOBAL": "ANONYMOUS" } ] },
      { "name": "role_attr", "attributes": [ { "CLAIM": "role" } ] }
    ],
    "DEFOBJECTS": [
      { "name": "health", "objects": [ { "ROUTE": "/health" } ] },
      { "name": "rules_collection", "objects": [ { "ROUTE": "/rules" } ] },
      { "name": "rules_item", "objects": [ { "ROUTE": "/rules/*" } ] },
      { "name": "all_rules", "objects": [ { "ROUTE": "/rules" }, { "ROUTE": "/rules/*" } ] },
      { "name": "shell_descriptors", "objects": [ { "ROUTE": "/shell-descriptors" } ] },
      { "name": "all_shell_descriptors", "objects": [ { "ROUTE": "/shell-descriptors" }, { "ROUTE": "/shell-descriptors/*" } ] },
      { "name": "god", "objects": [ { "ROUTE": "*" } ] }
    ],
    "DEFACLS": [
      { "name": "disabled_god", "acl": { "USEATTRIBUTES": "anonym_attr", "RIGHTS": ["CREATE", "READ", "UPDATE", "DELETE"], "ACCESS": "DISABLED" } },
      { "name": "read_public", "acl": { "USEATTRIBUTES": "anonym_attr", "RIGHTS": ["READ"], "ACCESS": "ALLOW" } },
      { "name": "read_role", "acl": { "USEATTRIBUTES": "role_attr", "RIGHTS": ["READ"], "ACCESS": "ALLOW" } },
      { "name": "admin_full", "acl": { "USEATTRIBUTES": "role_attr", "RIGHTS": ["CREATE", "READ", "UPDATE", "DELETE"], "ACCESS": "ALLOW" } },
      { "name": "admin_create", "acl": { "USEATTRIBUTES": "role_attr", "RIGHTS": ["CREATE"], "ACCESS": "ALLOW" } }
    ],
    "DEFFORMULAS": [
      { "name": "always_true", "formula": { "$boolean": true } },
      { "name": "isViewer", "formula": { "$eq": [ { "$attribute": { "CLAIM": "role" } }, { "$strVal": "viewer" } ] } },
      { "name": "isAdmin", "formula": { "$eq": [ { "$attribute": { "CLAIM": "role" } }, { "$strVal": "admin" } ] } }
    ],
    "rules": [
      { "USEACL": "disabled_god", "USEOBJECTS": ["god"], "USEFORMULA": "always_true" },
      { "USEACL": "read_public", "USEOBJECTS": ["health"], "USEFORMULA": "always_true" },
      { "USEACL": "read_role", "USEOBJECTS": ["all_rules"], "USEFORMULA": "isViewer" },
      { "USEACL": "admin_full", "USEOBJECTS": ["all_rules"], "USEFORMULA": "isAdmin" },
      { "USEACL": "read_role", "USEOBJECTS": ["all_shell_descriptors"], "USEFORMULA": "isViewer" },
      { "USEACL": "admin_create", "USEOBJECTS": ["shell_descriptors"], "USEFORMULA": "isAdmin" }
    ]
  }
}
