{
  "AllAccessPermissionRules": {
    "DEFATTRIBUTES": [
      { "name": "anonymous_attr", "attributes": [ { "GLOBAL": "ANONYMOUS" } ] },
      { "name": "username_attr", "attributes": [ { "CLAIM": "role" } ] }
    ],
    "DEFOBJECTS": [
      { "name": "public_description", "objects": [ { "ROUTE": "/description" }, { "ROUTE": "/api/v3/description" } ] },
      { "name": "all_api", "objects": [
        { "ROUTE": "/health" },
        { "ROUTE": "/shell-descriptors" },
        { "ROUTE": "/shell-descriptors/*" },
        { "ROUTE": "/submodel-descriptors" },
        { "ROUTE": "/submodel-descriptors/*" },
        { "ROUTE": "/lookup/shells" },
        { "ROUTE": "/lookup/shells/*" },
        { "ROUTE": "/lookup/shellsByAssetLink" },
        { "ROUTE": "/shells" },
        { "ROUTE": "/shells/*" },
        { "ROUTE": "/submodels" },
        { "ROUTE": "/submodels/*" },
        { "ROUTE": "/concept-descriptions" },
        { "ROUTE": "/concept-descriptions/*" }
      ] }
    ],
    "DEFACLS": [
      { "name": "anonymous_read", "acl": { "USEATTRIBUTES": "anonymous_attr", "RIGHTS": ["READ"], "ACCESS": "ALLOW" } },
      { "name": "usera_read", "acl": { "USEATTRIBUTES": "username_attr", "RIGHTS": ["READ"], "ACCESS": "ALLOW" } },
      { "name": "userb_read_write", "acl": { "USEATTRIBUTES": "username_attr", "RIGHTS": ["READ", "CREATE", "UPDATE"], "ACCESS": "ALLOW" } },
      { "name": "userx_all", "acl": { "USEATTRIBUTES": "username_attr", "RIGHTS": ["ALL"], "ACCESS": "ALLOW" } }
    ],
    "DEFFORMULAS": [
      { "name": "is_usera", "formula": { "$eq": [ { "$attribute": { "CLAIM": "role" } }, { "$strVal": "viewer" } ] } },
      { "name": "is_userb", "formula": { "$eq": [ { "$attribute": { "CLAIM": "role" } }, { "$strVal": "editor" } ] } },
      { "name": "is_userx", "formula": { "$eq": [ { "$attribute": { "CLAIM": "role" } }, { "$strVal": "admin" } ] } }
    ],
    "rules": [
      { "USEACL": "anonymous_read", "USEOBJECTS": ["public_description"], "FORMULA": {"$boolean": true} },
      { "USEACL": "usera_read", "USEOBJECTS": ["all_api"], "USEFORMULA": "is_usera" },
      { "USEACL": "userb_read_write", "USEOBJECTS": ["all_api"], "USEFORMULA": "is_userb" },
      { "USEACL": "userx_all", "USEOBJECTS": ["all_api"], "USEFORMULA": "is_userx" }
    ]
  }
}
