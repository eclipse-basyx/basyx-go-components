{
  "AllAccessPermissionRules": {
    "DEFATTRIBUTES": [
      { "name": "anonymous_attr", "attributes": [{ "GLOBAL": "ANONYMOUS" }] },
      { "name": "role_attr", "attributes": [{ "CLAIM": "role" }] }
    ],
    "DEFOBJECTS": [
      {
        "name": "public_description",
        "objects": [{ "ROUTE": "/description" }]
      },
      {
        "name": "public_product_info",
        "objects": [
          { "IDENTIFIABLE": "$aas(\"urn:fraunhofer:iese:dte:aas:drivemotor-dm3000:001\")" },
          { "DESCRIPTOR": "$aasdesc(\"urn:fraunhofer:iese:dte:aas:drivemotor-dm3000:001\")" },
          { "IDENTIFIABLE": "$sm(\"urn:fraunhofer:iese:dte:sm:nameplate:drivemotor-dm3000:001\")" },
          { "DESCRIPTOR": "$smdesc(\"urn:fraunhofer:iese:dte:sm:nameplate:drivemotor-dm3000:001\")" },
          { "IDENTIFIABLE": "$sm(\"urn:fraunhofer:iese:dte:sm:carbonfootprint:drivemotor-dm3000:001\")" },
          { "DESCRIPTOR": "$smdesc(\"urn:fraunhofer:iese:dte:sm:carbonfootprint:drivemotor-dm3000:001\")" }
        ]
      },
      {
        "name": "all_api",
        "objects": [
          { "ROUTE": "/health" },
          { "ROUTE": "/shell-descriptors" },
          { "ROUTE": "/shell-descriptors/*" },
          { "ROUTE": "/submodel-descriptors" },
          { "ROUTE": "/submodel-descriptors/*" },
          { "ROUTE": "/lookup/shells" },
          { "ROUTE": "/lookup/shells/*" },
          { "ROUTE": "/lookup/shellsByAssetLink" },
          { "ROUTE": "/shells" },
          { "ROUTE": "/shells/*" },
          { "ROUTE": "/submodels" },
          { "ROUTE": "/submodels/*" },
          { "ROUTE": "/concept-descriptions" },
          { "ROUTE": "/concept-descriptions/*" }
        ]
      }
    ],
    "DEFACLS": [
      { "name": "anonymous_read", "acl": { "USEATTRIBUTES": "anonymous_attr", "RIGHTS": ["READ"], "ACCESS": "ALLOW" } },
      { "name": "viewer_read", "acl": { "USEATTRIBUTES": "role_attr", "RIGHTS": ["READ"], "ACCESS": "ALLOW" } },
      { "name": "admin_full", "acl": { "USEATTRIBUTES": "role_attr", "RIGHTS": ["ALL"], "ACCESS": "ALLOW" } }
    ],
    "DEFFORMULAS": [
      { "name": "is_admin", "formula": { "$eq": [{ "$attribute": { "CLAIM": "role" } }, { "$strVal": "admin" }] } },
      { "name": "is_viewer", "formula": { "$eq": [{ "$attribute": { "CLAIM": "role" } }, { "$strVal": "viewer" }] } }
    ],
    "rules": [
      { "USEACL": "anonymous_read", "USEOBJECTS": ["public_description", "public_product_info"], "FORMULA": { "$boolean": true } },
      { "USEACL": "viewer_read", "USEOBJECTS": ["all_api"], "USEFORMULA": "is_viewer" },
      { "USEACL": "admin_full", "USEOBJECTS": ["all_api"], "USEFORMULA": "is_admin" }
    ]
  }
}
