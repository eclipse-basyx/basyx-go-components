    {
      "key": "carbonFootprintPathEncoded",
      "value": "%24%5B%27https%3A%2F%2Fadmin-shell.io%2Fidta%2FCarbonFootprint%2FCarbonFootprint%2F1%2F0%27%5D%5B%27ProductCarbonFootprints%27%5D",
      "type": "string"
