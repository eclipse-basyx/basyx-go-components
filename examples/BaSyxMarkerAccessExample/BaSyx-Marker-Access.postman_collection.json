eference\",\n          \"keys\": [\n            {\n              \"type\": \"GlobalReference\",\n              \"value\": \"BPN_COMPANY_001\"\n            },\n            {\n              \"type\": \"GlobalReference\",\n              \"value\": \"BPN_COMPANY_002\"\n            }\n          ]\n        }\n      ],\n      \"endpoints\": [\n        {\n          \"interface\": \"SUBMODEL-3.0\",\n          \"protocolInformation\": {\n            \"href\": \"http://localhost:5005/submodels/dXJuOmV4YW1wbGU6c3VibW9kZWw6c2VyaWFsLXBhcnQtdHlwaXphdGlvbg\",\n            \"endpointProtocol\": \"HTTP\"\n          }\n        }\n      ]\n    }\n  ]\n}"
