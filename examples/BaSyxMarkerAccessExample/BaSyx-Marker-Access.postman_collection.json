          "name": "Admin Sees All DTR Data",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('admin sees all descriptors, asset IDs, and markers', function () {",
                  "    pm.response.to.have.status(200);",
                  "    const shell = pm.response.json().result[0];",
                  "    pm.expect(shell.idShort).to.eql('ProductTwin');",
                  "    pm.expect(shell.specificAssetIds).to.have.length(2);",
                  "    pm.expect(shell.submodelDescriptors).to.have.length(2);",
                  "    const customerKeys = shell.specificAssetIds.find((item) => item.name === 'customerPartId').externalSubjectId.keys.map((key) => key.value);",
                  "    pm.expect(customerKeys).to.eql(['BPN_COMPANY_001', 'BPN_COMPANY_002']);",
                  "    const restrictedKeys = shell.submodelDescriptors.find((item) => item.idShort === 'RestrictedSerialPartTypization').supplementalSemanticId[0].keys.map((key) => key.value);",
                  "    pm.expect(restrictedKeys).to.eql(['BPN_COMPANY_001', 'BPN_COMPANY_002']);",
                  "});"
