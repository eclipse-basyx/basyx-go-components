{
  "info": {
    "_postman_id": "1d3fb989-0865-4b3c-9e9d-85d3e9a69d6a",
    "name": "BaSyx Marker Access Example",
    "description": "Walkthrough scenarios for the marker-based DTR and Submodel Repository access example. Start the Docker Compose stack from examples/BaSyxMarkerAccessExample before running the collection. Run the setup folder first; the collection pre-request script fetches OAuth2 password-grant tokens for protected requests and the setup writes the example shell descriptor and submodels.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const authHeader = pm.request.headers.get('Authorization') || '';",
          "const adminRequestNames = [",
          "    'Write Shell Descriptor As Admin',",
          "    'Write Public Submodel As Admin',",
          "    'Write Restricted Submodel As Admin',",
          "    'Admin Sees All DTR Data',",
          "    'Admin With Unrelated BPN Still Sees All DTR Data',",
          "    'Admin Sees All Submodels',",
          "    'Admin With Unrelated BPN Still Sees All Submodels'",
          "];",
          "const userRequestNames = [",
          "    'Regular Token Sees Public DTR Descriptor Only',",
          "    'Regular Token With BPN Company 1 Sees BPN1 DTR Data',",
          "    'Regular Token Sees Public Submodel Only',",
          "    'Regular Token With BPN Company 1 Sees BPN1 Submodels'",
          "];",
          "const needsAdminToken = authHeader.includes('{{adminAccessToken}}') || adminRequestNames.includes(pm.info.requestName);",
          "const needsUserToken = authHeader.includes('{{userAccessToken}}') || userRequestNames.includes(pm.info.requestName);",
          "const nowSeconds = Math.floor(Date.now() / 1000);",
          "",
          "function tokenIsFresh(expiresAtVariable) {",
          "    const expiresAt = Number(pm.collectionVariables.get(expiresAtVariable) || 0);",
          "    return expiresAt - 30 > nowSeconds;",
          "}",
          "",
          "function requestOAuth2Token(usernameVariable, passwordVariable, tokenVariable, expiresAtVariable) {",
          "    if (tokenIsFresh(expiresAtVariable)) {",
          "        return;",
          "    }",
          "",
          "    pm.sendRequest({",
          "        url: pm.collectionVariables.get('keycloakTokenUrl'),",
          "        method: 'POST',",
          "        header: {",
          "            'Content-Type': 'application/x-www-form-urlencoded'",
          "        },",
          "        body: {",
          "            mode: 'urlencoded',",
          "            urlencoded: [",
          "                { key: 'grant_type', value: 'password' },",
          "                { key: 'client_id', value: pm.collectionVariables.get('keycloakClientId') },",
          "                { key: 'username', value: pm.collectionVariables.get(usernameVariable) },",
          "                { key: 'password', value: pm.collectionVariables.get(passwordVariable) }",
          "            ]",
          "        }",
          "    }, function (error, response) {",
          "        if (error) {",
          "            throw new Error('OAuth2 token request failed: ' + error);",
          "        }",
          "",
          "        if (!response || response.code !== 200) {",
          "            throw new Error('OAuth2 token request failed with status ' + (response && response.code));",
          "        }",
          "",
          "        const tokenResponse = response.json();",
          "        pm.collectionVariables.set(tokenVariable, tokenResponse.access_token);",
          "        pm.collectionVariables.set(expiresAtVariable, nowSeconds + Number(tokenResponse.expires_in || 300));",
          "    });",
          "}",
          "",
          "if (needsAdminToken) {",
          "    requestOAuth2Token('adminUsername', 'adminPassword', 'adminAccessToken', 'adminAccessTokenExpiresAt');",
          "}",
          "",
          "if (needsUserToken) {",
          "    requestOAuth2Token('regularUsername', 'regularPassword', 'userAccessToken', 'userAccessTokenExpiresAt');",
          "}"
        ]
      }
    }
  ],
